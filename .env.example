# Bot Factory Environment Variables
# Copy this file to .env and fill in your actual values

# Required for intake bot
BOT_TOKEN=your_telegram_bot_token_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
DATABASE_URL=postgresql+asyncpg://admin:changeme@localhost:5432/botfactory
REDIS_URL=redis://localhost:6379

# Optional with defaults
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_AGENTS=deepseek/deepseek-chat-v3.1
OPENROUTER_MODEL_BOTS=deepseek/deepseek-chat-v3.1
ADMIN_TELEGRAM_IDS=

# YooKassa billing (required for payments)
YOOKASSA_SHOP_ID=your_yookassa_shop_id
YOOKASSA_SECRET_KEY=your_yookassa_secret_key
BILLING_RETURN_URL=https://t.me/

# Privacy / legal links (optional; included in consent text and /my_data)
PRIVACY_POLICY_URL=https://your-domain.com/privacy
TERMS_URL=https://your-domain.com/terms

# Postgres password for docker-compose
POSTGRES_PASSWORD=changeme

# For generated bots (usage reporting back to factory)
FACTORY_URL=http://host.docker.internal:8080
INTERNAL_API_KEY=

# Image generation (FusionBrain) - optional
FUSIONBRAIN_API_KEY=
FUSIONBRAIN_SECRET_KEY=

# RAG embeddings - optional
EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_MODEL=openai/text-embedding-3-small

# Deployment
REPO_URL=https://github.com/pohilkom89-ctrl/army-bot.git
